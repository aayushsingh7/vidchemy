# Debian-slim for better compatibility with OS-level packages
FROM node:20-slim

# Install FFmpeg and clean up the apt cache to keep the image size down
RUN apt-get update && \
    apt-get install -y ffmpeg && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY package*.json ./

RUN npm install

COPY . .

CMD ["node", "src/worker/ingestion.worker.js"]
